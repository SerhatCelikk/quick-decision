# Production environment — copy to .env.production and fill in values
# Used for EAS production builds and OTA updates on the production channel

APP_ENV=production

EXPO_PUBLIC_SUPABASE_URL=https://your-production-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key

# AdMob (real production IDs)
EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-XXXXXX~XXXXXXXX
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-XXXXXX~XXXXXXXX
EXPO_PUBLIC_ADMOB_INTERSTITIAL_IOS=ca-app-pub-XXXXXX/XXXXXXXX
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID=ca-app-pub-XXXXXX/XXXXXXXX
EXPO_PUBLIC_ADMOB_REWARDED_IOS=ca-app-pub-XXXXXX/XXXXXXXX
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID=ca-app-pub-XXXXXX/XXXXXXXX
